DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio
REDIS_URL=redis://localhost:6379/0

FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173
PORTFOLIO_REPOSITORY=memory
AUTH_SECRET_KEY=change-me-to-a-long-random-secret
DATA_ENCRYPTION_KEY=change-me-to-a-long-random-encryption-key

APP_HOSTS=localhost,127.0.0.1
ENABLE_HSTS=false
AUTH_DEV_EXPOSE_TOKENS=true
REFRESH_TOKEN_EXPIRE_SECONDS=2592000
PASSWORD_RESET_TOKEN_EXPIRE_SECONDS=900
EMAIL_VERIFICATION_TOKEN_EXPIRE_SECONDS=86400

MARKET_DATA_CACHE_TTL_SECONDS=900
MARKET_DATA_USER_REFRESH_LIMIT_PER_MINUTE=5
MARKET_DATA_USER_REFRESH_LIMIT_PER_DAY=100
MARKET_DATA_PORTFOLIO_REFRESH_MIN_SECONDS=0
MARKET_DATA_PROVIDER_FETCH_LIMIT_PER_MINUTE=1
MARKET_DATA_REQUIRE_REDIS_LIMITER=false
BACKGROUND_QUEUE_NAME=portfolio-jobs
PUBLIC_APP_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
