APP_ENV=development
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio
REDIS_URL=redis://localhost:6379/0

FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173
PORTFOLIO_REPOSITORY=memory
AUTH_SECRET_KEY=change-me-to-a-long-random-secret
DATA_ENCRYPTION_KEY=change-me-to-a-long-random-encryption-key

APP_HOSTS=localhost,127.0.0.1
ENABLE_HSTS=false
AUTH_DEV_EXPOSE_TOKENS=true
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
REFRESH_TOKEN_EXPIRE_SECONDS=2592000
PASSWORD_RESET_TOKEN_EXPIRE_SECONDS=900
EMAIL_VERIFICATION_TOKEN_EXPIRE_SECONDS=86400

MARKET_DATA_CACHE_TTL_SECONDS=900
MARKET_DATA_USER_REFRESH_LIMIT_PER_MINUTE=5
MARKET_DATA_USER_REFRESH_LIMIT_PER_DAY=100
MARKET_DATA_PORTFOLIO_REFRESH_MIN_SECONDS=0
MARKET_DATA_PROVIDER_FETCH_LIMIT_PER_MINUTE=10
MARKET_DATA_PROVIDER_GLOBAL_FETCH_LIMIT_PER_MINUTE=60
MARKET_DATA_PROVIDER_TICKERS_PER_COST_UNIT=5
MARKET_DATA_REQUIRE_REDIS_LIMITER=false
MARKET_DATA_MAX_REFRESH_TICKERS=50
MARKET_DATA_MAX_HISTORY_TICKERS=40
MARKET_DATA_MAX_BENCHMARK_TICKERS=8
OPTIONS_CHAIN_MAX_SURFACE_EXPIRIES=4
OPTIONS_CHAIN_PROVIDER_COST=2
OPTIONS_SUITE_PROVIDER_BASE_COST=2
OPTIONS_HISTORY_ALLOWED_PERIODS=1mo,3mo,6mo,1y,2y,5y
BACKGROUND_QUEUE_NAME=portfolio-jobs
PUBLIC_APP_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
AUTH_REQUIRE_REDIS_LIMITER=false
AUTH_RATE_LIMIT_LOGIN_IP_LIMIT=20
AUTH_RATE_LIMIT_LOGIN_EMAIL_LIMIT=8
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_REGISTER_IP_LIMIT=10
AUTH_RATE_LIMIT_REGISTER_EMAIL_LIMIT=4
AUTH_RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
AUTH_RATE_LIMIT_PASSWORD_RESET_REQUEST_IP_LIMIT=8
AUTH_RATE_LIMIT_PASSWORD_RESET_REQUEST_EMAIL_LIMIT=5
AUTH_RATE_LIMIT_PASSWORD_RESET_REQUEST_WINDOW_SECONDS=3600
