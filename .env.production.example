APP_DOMAIN=api.example.com
FRONTEND_ORIGINS=https://example.com,https://www.example.com
APP_HOSTS=api.example.com,localhost,127.0.0.1

POSTGRES_PASSWORD=replace-with-a-long-random-password
AUTH_SECRET_KEY=replace-with-a-long-random-auth-secret
DATA_ENCRYPTION_KEY=replace-with-a-long-random-data-encryption-secret

MARKET_DATA_CACHE_TTL_SECONDS=900
MARKET_DATA_USER_REFRESH_LIMIT_PER_MINUTE=5
MARKET_DATA_USER_REFRESH_LIMIT_PER_DAY=100
MARKET_DATA_PORTFOLIO_REFRESH_MIN_SECONDS=300
MARKET_DATA_PROVIDER_FETCH_LIMIT_PER_MINUTE=30
PUBLIC_APP_URL=https://example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
