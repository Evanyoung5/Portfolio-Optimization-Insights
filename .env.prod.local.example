APP_ENV=production
APP_DOMAIN=localhost
FRONTEND_ORIGINS=http://localhost
APP_HOSTS=localhost,127.0.0.1

POSTGRES_PASSWORD=replace-with-a-local-password
AUTH_SECRET_KEY=replace-with-a-long-local-auth-secret-at-least-32-chars
DATA_ENCRYPTION_KEY=replace-with-a-long-local-encryption-key-32-chars

AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
PUBLIC_APP_URL=http://localhost

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@localhost
SMTP_USE_TLS=false

MARKET_DATA_REQUIRE_REDIS_LIMITER=true
AUTH_REQUIRE_REDIS_LIMITER=true
